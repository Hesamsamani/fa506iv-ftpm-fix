<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <AssemblyName>FA506IV_fTPM_Fix</AssemblyName>
    <RootNamespace>FA506IV.FTPMFix.Gui</RootNamespace>
    <Version>1.3.3</Version>
    <Company>Hesamsamani</Company>
    <Product>ASUS FA506IV fTPM Fix</Product>
    <Description>GUI installer for FA506IV Warzone TPM attestation fix</Description>
    <ApplicationIcon>Assets\app.ico</ApplicationIcon>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
  </PropertyGroup>
  <ItemGroup>
    <EmbeddedResource Include="..\..\gui-payload.zip" Link="payload.zip" />
    <Resource Include="Assets\hero-banner.jpg" />
    <Resource Include="Assets\app-icon.png" />
    <Resource Include="Assets\app.ico" />
  </ItemGroup>
</Project>